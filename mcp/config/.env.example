# Open Wearables MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Backend API URL
# For local development with Docker: http://localhost:8000
# For production: https://api.your-domain.com
OPEN_WEARABLES_API_URL=http://localhost:8000

# Required: Your Open Wearables API key
# Get this from the Open Wearables developer portal or admin panel
OPEN_WEARABLES_API_KEY=ow_your_api_key_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Optional: IANA timezone for tool payloads (start_local / end_local) when a workout has no zone_offset.
# Use the same value as Coach BRIEFING_TIMEZONE when MCP and Coach serve the same athlete.
# USER_LOCAL_TIMEZONE=America/Los_Angeles
# Alias: BRIEFING_TIMEZONE (either env var is accepted)

# --- Remote MCP (streamable HTTP) ---
# Default is stdio for Cursor / Claude Desktop. Use streamable-http on a dedicated HTTPS deployment.
# MCP_TRANSPORT=stdio
# MCP_TRANSPORT=streamable-http

# HTTP auth mode (when MCP_TRANSPORT=streamable-http):
# - oauth: Claude custom connector (mobile, claude.ai) — GitHub login at connect time
# - bearer: Claude Managed Agents vault static_bearer
MCP_AUTH_MODE=oauth

# --- OAuth (MCP_AUTH_MODE=oauth) — Claude custom connector ---
# Public HTTPS origin of this MCP service (no trailing slash). Must match connector URL host.
# Example: https://open-wearables-mcp.up.railway.app
MCP_PUBLIC_BASE_URL=https://your-mcp-domain.example.com

# GitHub OAuth App: https://github.com/settings/developers
# Authorization callback URL: https://<MCP_PUBLIC_BASE_URL>/auth/callback
MCP_GITHUB_CLIENT_ID=
MCP_GITHUB_CLIENT_SECRET=

# Optional: stable signing key so OAuth tokens survive MCP container restarts
# MCP_JWT_SIGNING_KEY=

# MCP path must match your public URL (default /mcp → https://<host>/mcp)
# MCP_HTTP_PATH=/mcp
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_PORT=8765
# Railway sets PORT; when present it overrides MCP_HTTP_PORT.

# --- Bearer (MCP_AUTH_MODE=bearer) — Managed Agents only ---
# MCP_BEARER_TOKEN=
