# Open Wearables Coach configuration
# Copy this file to coach/config/.env and fill in your values.

# --- Open Wearables backend ---

# Base URL for the Open Wearables backend API.
# In docker compose this is http://app:8000; locally it is http://localhost:8000.
OPEN_WEARABLES_API_URL=http://localhost:8000

# API key for the single user this coach acts on behalf of.
# Generate one in the Open Wearables dashboard: Settings -> Credentials -> Create API Key.
OPEN_WEARABLES_API_KEY=ow_your_api_key_here

# UUID of the user the coach should brief. Avoids a get_users tool call every morning.
OW_USER_ID=00000000-0000-0000-0000-000000000000

# Path to the OW MCP server source directory. The coach spawns it as a stdio subprocess.
# In docker compose this is /opt/mcp; locally use ../mcp.
OW_MCP_DIR=../mcp

# --- Anthropic ---

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Telegram ---

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Chat ID for the recipient. Find via:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
# after sending the bot any message.
TELEGRAM_CHAT_ID=123456789

# --- Scheduling ---

BRIEFING_TIMEZONE=America/Los_Angeles
BRIEFING_TIME=07:00

# Use the same BRIEFING_TIMEZONE value in the MCP server (USER_LOCAL_TIMEZONE or BRIEFING_TIMEZONE there)
# so workout/sleep local times in tool results match this user.

# --- Storage ---

# SQLite database path for the briefing-run idempotency log.
COACH_DB_PATH=./coach.db

# --- Logging ---

LOG_LEVEL=INFO
